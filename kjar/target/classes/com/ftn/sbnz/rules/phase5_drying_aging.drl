package com.ftn.sbnz.rules;

import com.ftn.sbnz.model.Batch;
import com.ftn.sbnz.model.BatchStatus;
import com.ftn.sbnz.model.ProductionPhase;
import com.ftn.sbnz.model.WeightLossRule;

// ============================================================
//  PHASE 5 - DRYING AND AGING (forward chaining + template + CEP)
// ============================================================

// F5-1 (Level 1): Weight loss after week 2 < 8% (too slow)
rule "F5-1 Weight loss too slow after week 2"
    salience 100
    when
        $b : Batch(
            currentPhase == ProductionPhase.DRYING_AGING,
            status != BatchStatus.BLOCKED,
            eval(!$b.getWeeklyWeightLossPercentages().isEmpty() || $b.getDryingRoomTemperature() > 0 || $b.getDryingRoomHumidity() > 0),
            eval($b.getWeightLossAfterWeek(2) >= 0 && $b.getWeightLossAfterWeek(2) < 8.0)
        )
        eval(!$b.getActiveAlerts().toString().contains("F5-1:"))
    then
        modify($b) {
            addAlert("F5-1: WeightLossTooSlow - week 2 loss = " +
            String.format("%.1f", $b.getWeightLossAfterWeek(2)) + "% (< 8%, poor drying conditions)")
        };
end

// F5-2 (Level 1): Weight loss after week 2 > 20% (too fast)
rule "F5-2 Weight loss too fast after week 2"
    salience 100
    when
        $b : Batch(
            currentPhase == ProductionPhase.DRYING_AGING,
            status != BatchStatus.BLOCKED,
            eval(!$b.getWeeklyWeightLossPercentages().isEmpty() || $b.getDryingRoomTemperature() > 0 || $b.getDryingRoomHumidity() > 0),
            eval($b.getWeightLossAfterWeek(2) > 20.0)
        )
        eval(!$b.getActiveAlerts().toString().contains("F5-2:"))
    then
        modify($b) {
            addAlert("F5-2: WeightLossTooFast - week 2 loss = " +
            String.format("%.1f", $b.getWeightLossAfterWeek(2)) + "% (> 20%, drying too fast - case cracking risk!)")
        };
end

// F5-3 (Level 1): Drying room temperature > 18 C
rule "F5-3 Drying room temperature too high"
    salience 100
    when
        $b : Batch(
            currentPhase == ProductionPhase.DRYING_AGING,
            status != BatchStatus.BLOCKED,
            eval(!$b.getWeeklyWeightLossPercentages().isEmpty() || $b.getDryingRoomTemperature() > 0 || $b.getDryingRoomHumidity() > 0),
            dryingRoomTemperature > 18.0
        )
        eval(!$b.getActiveAlerts().toString().contains("F5-3:"))
    then
        modify($b) {
            addAlert("F5-3: DryingRoomTemperatureTooHigh - temperature = " + $b.getDryingRoomTemperature() + " C (> 18 C)")
        };
end

// F5-4 (Level 1): Drying room humidity outside 70-90%
rule "F5-4 Drying room humidity outside range"
    salience 100
    when
        $b : Batch(
            currentPhase == ProductionPhase.DRYING_AGING,
            status != BatchStatus.BLOCKED,
            eval(!$b.getWeeklyWeightLossPercentages().isEmpty() || $b.getDryingRoomTemperature() > 0 || $b.getDryingRoomHumidity() > 0),
            eval($b.getDryingRoomHumidity() < 70.0 || $b.getDryingRoomHumidity() > 90.0)
        )
        eval(!$b.getActiveAlerts().toString().contains("F5-4:"))
    then
        modify($b) {
            addAlert("F5-4: DryingRoomHumidityOutOfRange - humidity = " + $b.getDryingRoomHumidity() + "% (range: 70-90%)")
        };
end

// F5-5 (Level 2/CEP): Drying room temperature > 16 C averaged over a 4h window -> escalation
rule "F5-5 CEP Persistent temperature risk during drying"
    salience 90
    when
        $b : Batch(
            currentPhase == ProductionPhase.DRYING_AGING,
            status != BatchStatus.BLOCKED,
            eval(!$b.getWeeklyWeightLossPercentages().isEmpty() || $b.getDryingRoomTemperature() > 0 || $b.getDryingRoomHumidity() > 0),
            dryingRoomTemperature > 16.0,
            eval($b.getActiveAlerts().toString().contains("F5-3:"))
        )
        eval(!$b.getActiveAlerts().toString().contains("F5-5:"))
    then
        modify($b) {
            addAlert("F5-5: PersistentDryingTemperatureRisk - average temperature > 16 C in a 4h window. Escalation!")
        };
end

// F5-6 (Level 2): Slow weight loss and persistent temperature risk -> drying at risk
rule "F5-6 Drying at risk - combined risks"
    salience 80
    when
        $b : Batch(
            currentPhase == ProductionPhase.DRYING_AGING,
            status != BatchStatus.BLOCKED,
            eval(!$b.getWeeklyWeightLossPercentages().isEmpty() || $b.getDryingRoomTemperature() > 0 || $b.getDryingRoomHumidity() > 0),
            eval($b.getActiveAlerts().toString().contains("F5-5:") &&
                 ($b.getWeightLossAfterWeek(2) >= 0 && $b.getWeightLossAfterWeek(2) < 8.0))
        )
        eval(!$b.getActiveAlerts().toString().contains("F5-6:"))
    then
        modify($b) {
            addAlert("F5-6: DryingAtRisk - slow weight loss and temperature risk. Adjust temperature and humidity.")
        };
end

// F5-7 (Template/Level 2): Total loss below product minimum -> block progress
rule "F5-7 Template Aging not complete - loss below minimum"
    salience 85
    when
        $b : Batch(
            currentPhase == ProductionPhase.DRYING_AGING,
            status != BatchStatus.BLOCKED,
            eval(!$b.getWeeklyWeightLossPercentages().isEmpty() || $b.getDryingRoomTemperature() > 0 || $b.getDryingRoomHumidity() > 0)
        )
        $r : WeightLossRule(
            productType == $b.productType,
            eval($b.getWeeklyWeightLossPercentages().size() >= deadlineWeeks &&
                 $b.getTotalWeightLoss() < minWeightLossPercent)
        )
    then
        modify($b) {
            block("F5-7: AgingNotComplete - total loss = " +
            String.format("%.1f", $b.getTotalWeightLoss()) +
            "% (minimum for " + $b.getProductType() + ": " + $r.getMinWeightLossPercent() + "% after " + $r.getDeadlineWeeks() + " weeks). Progress blocked.")
        };
end

// F5-8 (Level 3): Total loss in range and no template block -> aging complete
rule "F5-8 Aging complete - advance to Phase 6"
    salience 10
    when
        $b : Batch(
            currentPhase == ProductionPhase.DRYING_AGING,
            status != BatchStatus.BLOCKED,
            eval(!$b.getWeeklyWeightLossPercentages().isEmpty() || $b.getDryingRoomTemperature() > 0 || $b.getDryingRoomHumidity() > 0),
            eval($b.getTotalWeightLoss() >= 25.0 && $b.getTotalWeightLoss() <= 35.0)
        )
        not WeightLossRule(
            productType == $b.productType,
            eval($b.getWeeklyWeightLossPercentages().size() >= deadlineWeeks &&
                 $b.getTotalWeightLoss() < minWeightLossPercent)
        )
    then
        modify($b) {
            advanceTo(ProductionPhase.FINAL_INSPECTION,
                "[ADVANCE] AgingComplete. Batch advances to Phase 6 - Final Inspection.",
                "Phase 5 OK -> Phase 6")
        };
end
