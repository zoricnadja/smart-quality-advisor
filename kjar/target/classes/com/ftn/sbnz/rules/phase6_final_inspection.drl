package com.ftn.sbnz.rules;

import com.ftn.sbnz.model.Batch;
import com.ftn.sbnz.model.BatchStatus;
import com.ftn.sbnz.model.ProductionPhase;

// ============================================================
//  PHASE 6 - FINAL INSPECTION
// ============================================================

// F6-1 (Level 1): final pH > 5.3 -> block
rule "F6-1 Final product pH unacceptable"
    salience 100
    when
        $b : Batch(
            currentPhase == ProductionPhase.FINAL_INSPECTION,
            status != BatchStatus.BLOCKED,
            eval($b.getFinalPh() > 0 || $b.getWaterActivity() > 0 || $b.getFinalVisualScore() > 0),
            finalPh > 5.3
        )
    then
        $b.block("F6-1: FinalPhUnacceptable - final pH = " + $b.getFinalPh() + " (> 5.3). Batch blocked.");
        update($b);
end

// F6-2 (Level 1): aw > 0.92 -> block
rule "F6-2 Water activity unacceptable"
    salience 100
    when
        $b : Batch(
            currentPhase == ProductionPhase.FINAL_INSPECTION,
            status != BatchStatus.BLOCKED,
            eval($b.getFinalPh() > 0 || $b.getWaterActivity() > 0 || $b.getFinalVisualScore() > 0),
            waterActivity > 0.92
        )
    then
        $b.block("F6-2: WaterActivityUnacceptable - aw = " + $b.getWaterActivity() + " (> 0.92, not shelf-stable without refrigeration). Batch blocked.");
        update($b);
end

// F6-3 (Level 1): Visual score < 4 -> warning
rule "F6-3 Final visual score unacceptable"
    salience 90
    when
        $b : Batch(
            currentPhase == ProductionPhase.FINAL_INSPECTION,
            status != BatchStatus.BLOCKED,
            eval($b.getFinalPh() > 0 || $b.getWaterActivity() > 0 || $b.getFinalVisualScore() > 0),
            finalVisualScore < 4
        )
        eval(!$b.getActiveAlerts().toString().contains("F6-3:"))
    then
        $b.addAlert("F6-3: FinalVisualScorePoor - final visual score = " + $b.getFinalVisualScore() + " (< 4)");
        update($b);
end

// F6-4 (Level 2): Poor visual score and unacceptable chemistry -> block
rule "F6-4 Final escalation block - visual score and chemistry"
    salience 80
    when
        $b : Batch(
            currentPhase == ProductionPhase.FINAL_INSPECTION,
            status != BatchStatus.BLOCKED,
            eval($b.getFinalPh() > 0 || $b.getWaterActivity() > 0 || $b.getFinalVisualScore() > 0),
            finalVisualScore < 4,
            eval($b.getFinalPh() > 5.3 || $b.getWaterActivity() > 0.92)
        )
    then
        $b.block("F6-4: BatchFinallyBlocked - poor visual score and unacceptable chemical parameters.");
        update($b);
end

// F6-5 (Level 3): All values OK -> batch approved
rule "F6-5 Batch approved - passed final inspection"
    salience 10
    when
        $b : Batch(
            currentPhase == ProductionPhase.FINAL_INSPECTION,
            status == BatchStatus.ACTIVE,
            eval($b.getFinalPh() > 0 || $b.getWaterActivity() > 0 || $b.getFinalVisualScore() > 0),
            finalPh <= 5.3,
            waterActivity <= 0.92,
            finalVisualScore >= 4
        )
    then
        $b.approve();
        update($b);
end