package com.ftn.sbnz.rules;

import com.ftn.sbnz.model.Serija;
import com.ftn.sbnz.model.StatusSerije;
import com.ftn.sbnz.model.FazaProizvodnje;

// ============================================================
//  FAZA 6 – FINALNA KONTROLA
// ============================================================

// F6-1 (Nivo 1): pH finalnog > 5.3 → blokada
rule "F6-1 pH finalnog proizvoda neprihvatljiv"
    salience 100
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FINALNA_KONTROLA,
            status != StatusSerije.BLOKIRANA,
            phFinalnog > 5.3
        )
    then
        $s.blokiraj("F6-1: PhFinalniNeprihvatljiv - pH finalnog = " + $s.getPhFinalnog() + " (> 5.3). Serija blokirana.");
        update($s);
end

// F6-2 (Nivo 1): aw > 0.92 → blokada (nije bezbjedan bez hlađenja)
rule "F6-2 Aw vrednost neprihvatljiva"
    salience 100
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FINALNA_KONTROLA,
            status != StatusSerije.BLOKIRANA,
            awVrednost > 0.92
        )
    then
        $s.blokiraj("F6-2: AwNeprihvatljiv - aw = " + $s.getAwVrednost() + " (> 0.92, nije bezbedan bez hlađenja). Serija blokirana.");
        update($s);
end

// F6-3 (Nivo 1): Vizuelna ocena < 4 → upozorenje
rule "F6-3 Vizuelna ocena finalnog neprihvatljiva"
    salience 90
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FINALNA_KONTROLA,
            status != StatusSerije.BLOKIRANA,
            vizuelnaOcenaFinalnog < 4
        )
    then
        $s.dodajUpozorenje("F6-3: VisualnaOcenaLosa - vizuelna ocena finalnog = " + $s.getVizuelnaOcenaFinalnog() + " (< 4)");
        update($s);
end

// F6-4 (Nivo 2): VisualnaOcenaLoša I (PhFinalniNeprihvatljiv ILI AwNeprihvatljiv) → blokada
rule "F6-4 Eskalacija finalna blokada - ocena i hemija"
    salience 80
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FINALNA_KONTROLA,
            status != StatusSerije.BLOKIRANA,
            vizuelnaOcenaFinalnog < 4,
            eval($s.getPhFinalnog() > 5.3 || $s.getAwVrednost() > 0.92)
        )
    then
        $s.blokiraj("F6-4: SerijaFinalnoBlokirana - loša vizuelna ocena I neprihvatljivi hemijski parametri.");
        update($s);
end

// F6-5 (Nivo 3): Sve vrednosti OK → SerijaOdobrena
rule "F6-5 Serija odobrena - prolazi finalnu kontrolu"
    salience 10
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FINALNA_KONTROLA,
            status != StatusSerije.BLOKIRANA,
            phFinalnog <= 5.3,
            awVrednost <= 0.92,
            vizuelnaOcenaFinalnog >= 4
        )
    then
        $s.odobri();
        update($s);
end
