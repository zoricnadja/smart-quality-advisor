package com.ftn.sbnz.rules;

import com.ftn.sbnz.model.Serija;
import com.ftn.sbnz.model.StatusSerije;
import com.ftn.sbnz.model.FazaProizvodnje;
import java.time.LocalDate;

// ============================================================
//  FAZA 1 – PRIJEM SIROVINE
// ============================================================

// F1-1 (Nivo 1): pH > 6.5 → odmah blokada
rule "F1-1 pH prijema kritičan - odmah blokada"
    salience 100
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.PRIJEM,
            status != StatusSerije.BLOKIRANA,
            phPrijema > 6.5
        )
    then
        $s.blokiraj("F1-1: pH pri prijemu je " + $s.getPhPrijema() + " (kritično > 6.5). Serija odbijena.");
        update($s);
end

// F1-2 (Nivo 1): pH između 6.2 i 6.5 → upozorenje
rule "F1-2 pH prijema visok - upozorenje"
    salience 90
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.PRIJEM,
            status != StatusSerije.BLOKIRANA,
            phPrijema > 6.2,
            phPrijema <= 6.5
        )
    then
        $s.dodajUpozorenje("F1-2: UpozorenjePhPrijema - pH = " + $s.getPhPrijema() + " (opseg 6.2–6.5, potrebna potvrda)");
        update($s);
end

// F1-3 (Nivo 1): Temperatura > 7°C → upozorenje
rule "F1-3 Temperatura prijema visoka"
    salience 90
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.PRIJEM,
            status != StatusSerije.BLOKIRANA,
            temperaturaPrijema > 7.0
        )
    then
        $s.dodajUpozorenje("F1-3: TemperaturaPrijemaVisoka - temp = " + $s.getTemperaturaPrijema() + "°C (> 7°C)");
        update($s);
end

// F1-4 (Nivo 1): Rok trajanja < 5 dana → upozorenje
rule "F1-4 Rok trajanja sirovine kratak"
    salience 90
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.PRIJEM,
            status != StatusSerije.BLOKIRANA,
            rokTrajanjaSirovine != null,
            eval($s.getDaneDoPistekaPodataka() < 5)
        )
    then
        $s.dodajUpozorenje("F1-4: RokTrajanjaSirovineKratak - preostalo " + $s.getDaneDoPistekaPodataka() + " dana do isteka roka");
        update($s);
end

// F1-5 (Nivo 2): Temp visoka I rok kratak → eskalacija, blokada
rule "F1-5 Eskalacija - temperatura i rok zajedno"
    salience 80
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.PRIJEM,
            status != StatusSerije.BLOKIRANA,
            eval($s.imaAktivnoUpozorenje("F1-3: TemperaturaPrijemaVisoka - temp = " + $s.getTemperaturaPrijema() + "°C (> 7°C)")),
            eval($s.imaAktivnoUpozorenje("F1-4: RokTrajanjaSirovineKratak - preostalo " + $s.getDaneDoPistekaPodataka() + " dana do isteka roka"))
        )
    then
        $s.blokiraj("F1-5: SirovinaNeprihvatljiva - temperatura visoka I rok kratak istovremeno.");
        update($s);
end

// F1-6 (Nivo 2): Vizuelna ocena < 3 → blokada
rule "F1-6 Vizuelna ocena neprihvatljiva"
    salience 85
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.PRIJEM,
            status != StatusSerije.BLOKIRANA,
            vizuelnaOcenaPrijema < 3
        )
    then
        $s.blokiraj("F1-6: SirovinaNeprihvatljiva - vizuelna ocena = " + $s.getVizuelnaOcenaPrijema() + " (< 3).");
        update($s);
end

// Napredak u Fazu 2: pH ≤ 6.2, temp ≤ 7°C, ocena ≥ 3, nema blokade
rule "F1 Serija može napredovati u Fazu 2"
    salience 10
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.PRIJEM,
            status != StatusSerije.BLOKIRANA,
            phPrijema <= 6.2,
            temperaturaPrijema <= 7.0,
            vizuelnaOcenaPrijema >= 3
        )
    then
        $s.getLog().add("[NAPREDAK] Faza 1 uspešno završena. Serija napreduje u Fazu 2 – Salamurenje.");
        System.out.println("  >> NAPREDAK [" + $s.getId() + "]: Faza 1 OK → Faza 2");
        $s.setTrenutnaFaza(FazaProizvodnje.SALAMURENJE);
        update($s);
end
