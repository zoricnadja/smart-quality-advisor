package com.ftn.sbnz.rules;

import com.ftn.sbnz.model.Serija;
import com.ftn.sbnz.model.StatusSerije;
import com.ftn.sbnz.model.FazaProizvodnje;

// ============================================================
//  FAZA 3 â€“ FERMENTACIJA (forward chaining + CEP trend pH)
// ============================================================

// F3-0 Guard: serija uÅ¡la u Fazu 3 bez pH podataka â†’ ostaje, Äeka unos
// SprjeÄava beskonaÄnu re-evaluaciju kad lista nije popunjena
rule "F3-0 Guard â€“ nedovoljno pH unosa za evaluaciju"
    salience 200
    no-loop
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FERMENTACIJA,
            status != StatusSerije.BLOKIRANA
        )
        eval($s.getPhFermentacijePoFazama().size() < 5)
    then
        if (!$s.imaAktivnoUpozorenje("F3-0: NedovoljnoPhUnosa")) {
            $s.dodajUpozorenje("F3-0: NedovoljnoPhUnosa â€“ potrebno je 5 dnevnih pH unosa (trenutno: "
                + $s.getPhFermentacijePoFazama().size() + "). Fermentacija u toku.");
            update($s);
        }
end

// F3-1 (Nivo 1): pH na dan 1 > 6.0
rule "F3-1 pH fermentacije visok na dan 1"
    salience 100
    no-loop
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FERMENTACIJA,
            status != StatusSerije.BLOKIRANA
        )
        eval(!$s.getAktivnaUpozorenja().toString().contains("F3-1:"))
        eval($s.getPhNaDan(1) > 6.0 && $s.getPhNaDan(1) > 0)
    then
        $s.dodajUpozorenje("F3-1: PhFermentacijeVisok_D1 - pH dan 1 = " + $s.getPhNaDan(1) + " (> 6.0, fermentacija sporo kreÄ‡e)");
        update($s);
end

// F3-2 (Nivo 1): pH na dan 3 > 5.6
rule "F3-2 pH fermentacije visok na dan 3"
    salience 100
    no-loop
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FERMENTACIJA,
            status != StatusSerije.BLOKIRANA
        )
        eval(!$s.getAktivnaUpozorenja().toString().contains("F3-2:"))
        eval($s.getPhNaDan(3) > 5.6 && $s.getPhNaDan(3) > 0)
    then
        $s.dodajUpozorenje("F3-2: PhFermentacijeVisok_D3 - pH dan 3 = " + $s.getPhNaDan(3) + " (> 5.6, fermentacija zaostaje)");
        update($s);
end

// F3-3 (Nivo 1): pH na dan 5 > 5.3 â†’ fermentacija neuspjeÅ¡na
rule "F3-3 pH fermentacije kritiÄan na dan 5"
    salience 100
    no-loop
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FERMENTACIJA,
            status != StatusSerije.BLOKIRANA
        )
        eval(!$s.getAktivnaUpozorenja().toString().contains("F3-3:"))
        eval($s.getPhFermentacijePoFazama().size() == 5 &&
        $s.getPhNaDan(5) > 5.3 && $s.getPhNaDan(5) > 0)
    then
        $s.dodajUpozorenje("F3-3: PhFermentacijeFailed - pH dan 5 = " + $s.getPhNaDan(5) + " (> 5.3, fermentacija neuspeÅ¡na)");
        update($s);
end

// F3-4 (Nivo 1): pH na dan 5 izmeÄ‘u 5.3 i 5.6 â†’ preporuka za produÅ¾etak
rule "F3-4 pH fermentacije graniÄni na dan 5"
    salience 95
    no-loop
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FERMENTACIJA,
            status != StatusSerije.BLOKIRANA
        )
        eval(!$s.getAktivnaUpozorenja().toString().contains("F3-4:"))
        eval($s.getPhFermentacijePoFazama().size() == 5 &&
             $s.getPhNaDan(5) > 5.3 && $s.getPhNaDan(5) <= 5.6 && $s.getPhNaDan(5) > 0)
    then
        $s.dodajUpozorenje("F3-4: PhFermentacijeGranican - pH dan 5 = " + $s.getPhNaDan(5) + ". PreporuÄuje se produÅ¾etak fermentacije 1â€“2 dana.");
        update($s);
end

// F3-5 (Nivo 2/CEP): Trend pada pH previÅ¡e spor izmeÄ‘u 2 uzastopna dana (delta < 0.1)
rule "F3-5 CEP Trend pH previÅ¡e sporo opada - dan 2"
    salience 90
    no-loop
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FERMENTACIJA,
            status != StatusSerije.BLOKIRANA
        )
        eval(!$s.getAktivnaUpozorenja().toString().contains("F3-5: TrendPhPreSporoOpada_D2"))
        eval($s.getPhFermentacijePoFazama().size() == 5 &&
             $s.getDeltaPhIzmedjuDana(2) >= 0 && $s.getDeltaPhIzmedjuDana(2) < 0.1 && $s.getPhNaDan(2) > 0)
    then
        $s.dodajUpozorenje("F3-5: TrendPhPreSporoOpada_D2 - delta pH dan 1â†’2 = " + String.format("%.2f", $s.getDeltaPhIzmedjuDana(2)) + " (< 0.1)");
        update($s);
end

