        update($s);
end

// F3-6 (Nivo 2/CEP): 2+ uzastopna spora trenda â†’ FermentacijaUgrozena
rule "F3-6 CEP Fermentacija ugrozena - spor trend 2+ dana"
    salience 80
    no-loop
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FERMENTACIJA,
            status != StatusSerije.BLOKIRANA
        )
        eval(!$s.getAktivnaUpozorenja().toString().contains("F3-6:"))
        eval(
            $s.getPhFermentacijePoFazama().size() == 5 &&
            (
                ($s.getDeltaPhIzmedjuDana(2) >= 0 && $s.getDeltaPhIzmedjuDana(2) < 0.1 && $s.getPhNaDan(2) > 0 &&
                 $s.getDeltaPhIzmedjuDana(3) >= 0 && $s.getDeltaPhIzmedjuDana(3) < 0.1 && $s.getPhNaDan(3) > 0) ||
                ($s.getDeltaPhIzmedjuDana(3) >= 0 && $s.getDeltaPhIzmedjuDana(3) < 0.1 && $s.getPhNaDan(3) > 0 &&
                 $s.getDeltaPhIzmedjuDana(4) >= 0 && $s.getDeltaPhIzmedjuDana(4) < 0.1 && $s.getPhNaDan(4) > 0) ||
                ($s.getDeltaPhIzmedjuDana(4) >= 0 && $s.getDeltaPhIzmedjuDana(4) < 0.1 && $s.getPhNaDan(4) > 0 &&
                 $s.getDeltaPhIzmedjuDana(5) >= 0 && $s.getDeltaPhIzmedjuDana(5) < 0.1 && $s.getPhNaDan(5) > 0)
            )
        )
    then
        $s.dodajUpozorenje("F3-6: FermentacijaUgrozena - spor trend pH 2+ uzastopna dana. PreporuÄuje se provera starter kulture.");
        update($s);
end

// F3-7 (Nivo 2/CEP): Temperatura komore > 26Â°C â†’ rizik od patogena
rule "F3-7 CEP Temperatura fermentacijske komore previsoka"
    salience 90
    no-loop
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FERMENTACIJA,
            status != StatusSerije.BLOKIRANA,
            temperaturaFermentacijskeKomore > 26.0
        )
        eval(!$s.getAktivnaUpozorenja().toString().contains("F3-7:"))
    then
        $s.dodajUpozorenje("F3-7: TempFermentacijePrevisoka - temperatura komore = " + $s.getTemperaturaFermentacijskeKomore() + "Â°C (> 26Â°C, rizik od patogena!)");
        update($s);
end

// F3-8 (Nivo 3): PhFermentacijeFailed ILI (FermentacijaUgrozena I TempPrevisoka) â†’ blokada
rule "F3-8 Fermentacija failed - blokada serije"
    salience 70
    no-loop
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FERMENTACIJA,
            status != StatusSerije.BLOKIRANA
        )
        eval(
            $s.getPhFermentacijePoFazama().size() == 5 &&
            (
                $s.getAktivnaUpozorenja().toString().contains("F3-3:") ||
                ($s.getAktivnaUpozorenja().toString().contains("F3-6:") &&
                 $s.getAktivnaUpozorenja().toString().contains("F3-7:"))
            )
        )
    then
        $s.blokiraj("F3-8: FermentacijaFailed - serija blokirana. Ne moÅ¾e napredovati u Fazu 4.");
        update($s);
end

// F3-9 (Nivo 3): pH < 5.3 na dan 5, nema aktivnih upozorenja â†’ uspeÅ¡na fermentacija
rule "F3-9 Fermentacija uspeÅ¡na - napredak u Fazu 4"
    salience 10
    when
        $s : Serija(
            trenutnaFaza == FazaProizvodnje.FERMENTACIJA,
            status != StatusSerije.BLOKIRANA,
            temperaturaFermentacijskeKomore >= 18.0,
            temperaturaFermentacijskeKomore <= 24.0,
            vlaznostFermentacijskeKomore >= 85.0,
            vlaznostFermentacijskeKomore <= 95.0
        )
        eval($s.getPhFermentacijePoFazama().size() == 5 &&
        $s.getPhNaDan(5) > 0 && $s.getPhNaDan(5) < 5.3)
    then
        $s.getLog().add("[NAPREDAK] FermentacijaUspesna. Serija napreduje u Fazu 4 â€“ Dimljenje.");
        System.out.println("  >> NAPREDAK [" + $s.getId() + "]: Faza 3 OK â†’ Faza 4");
        $s.setTrenutnaFaza(FazaProizvodnje.DIMLJENJE);
        update($s);
end
