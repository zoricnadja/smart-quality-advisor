package com.ftn.sbnz.rules;

import com.ftn.sbnz.model.Batch;
import com.ftn.sbnz.model.BatchStatus;
import com.ftn.sbnz.model.ProductionPhase;

// ============================================================
//  PHASE 4 - SMOKING (forward chaining + temperature aggregation)
// ============================================================

// F4-1 (Level 1): Smoke temperature > 90 C -> case hardening warning
rule "F4-1 Smoke temperature too high"
    salience 100
    when
        $b : Batch(
            currentPhase == ProductionPhase.SMOKING,
            status != BatchStatus.BLOCKED,
            eval($b.getSmokeTemperature() > 0 || $b.getSmokingDurationHours() > 0),
            smokeTemperature > 90.0
        )
        eval(!$b.getActiveAlerts().toString().contains("F4-1:"))
    then
        $b.addAlert("F4-1: SmokeTemperatureTooHigh - temperature = " + $b.getSmokeTemperature() + " C (> 90 C, case hardening risk)");
        update($b);
end

// F4-2 (Level 1): Smoke temperature < 55 C -> insufficient heat treatment warning
rule "F4-2 Smoke temperature too low"
    salience 100
    when
        $b : Batch(
            currentPhase == ProductionPhase.SMOKING,
            status != BatchStatus.BLOCKED,
            eval($b.getSmokeTemperature() > 0 || $b.getSmokingDurationHours() > 0),
            smokeTemperature < 55.0
        )
        eval(!$b.getActiveAlerts().toString().contains("F4-2:"))
    then
        $b.addAlert("F4-2: SmokeTemperatureTooLow - temperature = " + $b.getSmokeTemperature() + " C (< 55 C, insufficient heat treatment risk)");
        update($b);
end

// F4-3 (Level 2/CEP): Average smoke temperature < 60 C in a 15-minute window
rule "F4-3 CEP Insufficient heat treatment in 15-minute window"
    salience 90
    when
        $b : Batch(
            currentPhase == ProductionPhase.SMOKING,
            status != BatchStatus.BLOCKED,
            eval($b.getSmokeTemperature() > 0 || $b.getSmokingDurationHours() > 0),
            smokeTemperature < 60.0
        )
        eval(!$b.getActiveAlerts().toString().contains("F4-3:"))
    then
        $b.addAlert("F4-3: InsufficientHeatTreatment15min - average smoke temperature = " + $b.getSmokeTemperature() + " C (< 60 C in 15-minute window)");
        update($b);
end

// F4-4 (Level 2/CEP chaining): Insufficient heat treatment for 45+ minutes
rule "F4-4 CEP Insufficient heat treatment for 45+ minutes - critical"
    salience 85
    when
        $b : Batch(
            currentPhase == ProductionPhase.SMOKING,
            status != BatchStatus.BLOCKED,
            eval($b.getSmokeTemperature() > 0 || $b.getSmokingDurationHours() > 0),
            smokeTemperature < 60.0,
            eval($b.getActiveAlerts().toString().contains("F4-3:"))
        )
        eval(!$b.getActiveAlerts().toString().contains("F4-4:"))
    then
        $b.addAlert("F4-4: InsufficientHeatTreatment - smoke temperature < 60 C for 3+ consecutive 15-minute windows (total >= 45 min). CRITICAL!");
        update($b);
end

// F4-5 (Level 3): InsufficientHeatTreatment -> block
rule "F4-5 Smoking failed - block"
    salience 75
    when
        $b : Batch(
            currentPhase == ProductionPhase.SMOKING,
            status != BatchStatus.BLOCKED,
            eval($b.getSmokeTemperature() > 0 || $b.getSmokingDurationHours() > 0),
            eval($b.getActiveAlerts().toString().contains("F4-4:"))
        )
    then
        $b.block("F4-5: SmokingFailed - insufficient heat treatment. Repeat smoking or discard the batch.");
        update($b);
end

// F4-6 (Level 2): Total smoking duration > 10h -> warning
rule "F4-6 Smoking duration too long"
    salience 90
    when
        $b : Batch(
            currentPhase == ProductionPhase.SMOKING,
            status != BatchStatus.BLOCKED,
            eval($b.getSmokeTemperature() > 0 || $b.getSmokingDurationHours() > 0),
            smokingDurationHours > 10
        )
        eval(!$b.getActiveAlerts().toString().contains("F4-6:"))
    then
        $b.addAlert("F4-6: SmokingDurationTooLong - duration = " + $b.getSmokingDurationHours() + "h (> 10h, excessive processing)");
        update($b);
end

// F4-7 (Level 3): Temperature in range + duration 4-8h -> smoking successful
rule "F4-7 Smoking successful - advance to Phase 5"
    salience 10
    when
        $b : Batch(
            currentPhase == ProductionPhase.SMOKING,
            status != BatchStatus.BLOCKED,
            eval($b.getSmokeTemperature() > 0 || $b.getSmokingDurationHours() > 0),
            smokeTemperature >= 60.0,
            smokeTemperature <= 85.0,
            smokingDurationHours >= 4,
            smokingDurationHours <= 8
        )
    then
        $b.getLog().add("[ADVANCE] SmokingSuccessful. Batch advances to Phase 5 - Drying/Aging.");
        System.out.println("  >> ADVANCE [" + $b.getId() + "]: Phase 4 OK -> Phase 5");
        $b.setCurrentPhase(ProductionPhase.DRYING_AGING);
        update($b);
end