package com.ftn.sbnz.rules;

import com.ftn.sbnz.model.Batch;
import com.ftn.sbnz.model.BatchStatus;
import com.ftn.sbnz.model.ProductionPhase;
import com.ftn.sbnz.model.SaltRule;

// ============================================================
//  PHASE 2 - CURING
// ============================================================

// F2-1 (Level 1): Salt < 1.8% -> block
rule "F2-1 Salt below minimum safe value"
    salience 100
    when
        $b : Batch(
            currentPhase == ProductionPhase.CURING,
            status != BatchStatus.BLOCKED,
            eval($b.getSaltPercentage() > 0 || $b.getBrineTemperature() > 0 || $b.getCuringDurationHours() > 0),
            saltPercentage < 1.8
        )
    then
        modify($b) {
            block("F2-1: Salt = " + $b.getSaltPercentage() + "% - below the 1.8% safety minimum. Batch blocked.")
        };
end

rule "F2-2 Salt outside range for product type (Template)"
    salience 90
    no-loop
    when
        $b : Batch(
            currentPhase == ProductionPhase.CURING,
            status != BatchStatus.BLOCKED,
            eval($b.getSaltPercentage() > 0 || $b.getBrineTemperature() > 0 || $b.getCuringDurationHours() > 0)
        )
        $r : SaltRule(
            productType == $b.productType,
            eval($b.getSaltPercentage() < minSalt || $b.getSaltPercentage() > maxSalt)
        )
        eval(!$b.getActiveAlerts().toString().contains("F2-2:"))
    then
        modify($b) {
            addAlert("F2-2: SaltOutOfRange - salt = " + $b.getSaltPercentage() +
            "% (range for " + $b.getProductType() + ": " + $r.getMinSalt() + "-" + $r.getMaxSalt() + "%)")
        };
end

rule "F2-3 Brine temperature high"
    salience 90
    no-loop
    when
        $b : Batch(
            currentPhase == ProductionPhase.CURING,
            status != BatchStatus.BLOCKED,
            eval($b.getSaltPercentage() > 0 || $b.getBrineTemperature() > 0 || $b.getCuringDurationHours() > 0),
            brineTemperature > 8.0
        )
        eval(!$b.getActiveAlerts().toString().contains("F2-3:"))
    then
        modify($b) {
            addAlert("F2-3: BrineTemperatureHigh - temperature = " + $b.getBrineTemperature() + " C (> 8 C, danger zone!)")
        };
end

rule "F2-4 Brine temperature low"
    salience 90
    no-loop
    when
        $b : Batch(
            currentPhase == ProductionPhase.CURING,
            status != BatchStatus.BLOCKED,
            eval($b.getSaltPercentage() > 0 || $b.getBrineTemperature() > 0 || $b.getCuringDurationHours() > 0),
            brineTemperature < 2.0
        )
        eval(!$b.getActiveAlerts().toString().contains("F2-4:"))
    then
        modify($b) {
            addAlert("F2-4: BrineTemperatureLow - temperature = " + $b.getBrineTemperature() + " C (< 2 C)")
        };
end

// F2-5 (Level 2/CEP): Active high-temperature warning -> block
rule "F2-5 CEP Brine temperature high too long - block"
    salience 80
    when
        $b : Batch(
            currentPhase == ProductionPhase.CURING,
            status != BatchStatus.BLOCKED,
            eval($b.getSaltPercentage() > 0 || $b.getBrineTemperature() > 0 || $b.getCuringDurationHours() > 0),
            eval($b.getActiveAlerts().toString().contains("F2-3:"))
        )
    then
        modify($b) {
            block("F2-5: CuringFailed - brine temperature remained high too long (> 2h). Spoilage risk.")
        };
end

// F2-6 (Level 1): Curing duration outside 24-96h
rule "F2-6 Curing duration invalid"
    salience 85
    no-loop
    when
        $b : Batch(
            currentPhase == ProductionPhase.CURING,
            status != BatchStatus.BLOCKED,
            eval($b.getSaltPercentage() > 0 || $b.getBrineTemperature() > 0 || $b.getCuringDurationHours() > 0),
            curingDurationHours < 24 || curingDurationHours > 96
        )
        eval(!$b.getActiveAlerts().toString().contains("F2-6:"))
    then
        modify($b) {
            addAlert("F2-6: CuringDurationInvalid - duration = " + $b.getCuringDurationHours() + "h (range: 24-96h)")
        };
end

rule "F2 Batch can advance to Phase 3"
    salience 10
    when
        $b : Batch(
            currentPhase == ProductionPhase.CURING,
            status != BatchStatus.BLOCKED,
            eval($b.getSaltPercentage() > 0 || $b.getBrineTemperature() > 0 || $b.getCuringDurationHours() > 0),
            saltPercentage >= 1.8,
            brineTemperature >= 2.0,
            brineTemperature <= 8.0,
            curingDurationHours >= 24,
            curingDurationHours <= 96,
            activeAlerts.isEmpty() == true
        )
    then
        modify($b) {
            advanceTo(ProductionPhase.FERMENTATION,
                "[ADVANCE] Phase 2 completed successfully. Batch advances to Phase 3 - Fermentation.",
                "Phase 2 OK -> Phase 3")
        };
end
