package com.ftn.sbnz.rules;

import com.ftn.sbnz.model.Batch;
import com.ftn.sbnz.model.BatchStatus;
import com.ftn.sbnz.model.ProductionPhase;

// ============================================================
//  PHASE 1 - RAW MATERIAL RECEIVING
// ============================================================

// F1-1 (Level 1): pH > 6.5 -> immediate block
rule "F1-1 Receiving pH critical - immediate block"
    salience 100
    when
        $b : Batch(
            currentPhase == ProductionPhase.RECEIVING,
            status != BatchStatus.BLOCKED,
            receivingPh > 6.5
        )
    then
        modify($b) {
            block("F1-1: Receiving pH is " + $b.getReceivingPh() + " (critical > 6.5). Batch rejected.")
        };
end

// F1-2 (Level 1): pH between 6.2 and 6.5 -> warning
rule "F1-2 Receiving pH high - warning"
    salience 90
    when
        $b : Batch(
            currentPhase == ProductionPhase.RECEIVING,
            status != BatchStatus.BLOCKED,
            receivingPh > 6.2,
            receivingPh <= 6.5,
            !hasActiveAlert("F1-2:")
        )
    then
        modify($b) {
            addAlert("F1-2: ReceivingPhWarning - pH = " + $b.getReceivingPh() + " (range 6.2-6.5, confirmation required)")
        };
end

// F1-3 (Level 1): Temperature > 7 C -> warning
rule "F1-3 Receiving temperature high"
    salience 90
    when
        $b : Batch(
            currentPhase == ProductionPhase.RECEIVING,
            status != BatchStatus.BLOCKED,
            receivingTemperature > 7.0,
            !hasActiveAlert("F1-3:")
        )
    then
        modify($b) {
            addAlert("F1-3: ReceivingTemperatureHigh - temperature = " + $b.getReceivingTemperature() + " C (> 7 C)")
        };
end

// F1-4 (Level 1): Shelf life < 5 days -> warning
rule "F1-4 Raw material shelf life short"
    salience 90
    when
        $b : Batch(
            currentPhase == ProductionPhase.RECEIVING,
            status != BatchStatus.BLOCKED,
            rawMaterialShelfLife != null,
            daysUntilRawMaterialExpiry < 5,
            !hasActiveAlert("F1-4:")
        )
    then
        modify($b) {
            addAlert("F1-4: RawMaterialShelfLifeShort - " + $b.getDaysUntilRawMaterialExpiry() + " days left until expiry")
        };
end

// F1-5 (Level 2): High temperature and short shelf life -> block
rule "F1-5 Escalation - temperature and shelf life together"
    salience 80
    when
        $b : Batch(
            currentPhase == ProductionPhase.RECEIVING,
            status != BatchStatus.BLOCKED,
            hasActiveAlert("F1-3:"),
            hasActiveAlert("F1-4:")
        )
    then
        modify($b) {
            block("F1-5: RawMaterialUnacceptable - high temperature and short shelf life at the same time.")
        };
end

// F1-6 (Level 2): Visual score < 3 -> block
rule "F1-6 Visual score unacceptable"
    salience 85
    when
        $b : Batch(
            currentPhase == ProductionPhase.RECEIVING,
            status != BatchStatus.BLOCKED,
            receivingVisualScore < 3
        )
    then
        modify($b) {
            block("F1-6: RawMaterialUnacceptable - visual score = " + $b.getReceivingVisualScore() + " (< 3).")
        };
end

// Advance to Phase 2: pH <= 6.2, temp <= 7 C, score >= 3, no block
rule "F1 Batch can advance to Phase 2"
    salience 10
    when
        $b : Batch(
            currentPhase == ProductionPhase.RECEIVING,
            status != BatchStatus.BLOCKED,
            receivingPh <= 6.2,
            receivingTemperature <= 7.0,
            receivingVisualScore >= 3
        )
    then
        modify($b) {
            advanceTo(ProductionPhase.CURING,
                "[ADVANCE] Phase 1 completed successfully. Batch advances to Phase 2 - Curing.",
                "Phase 1 OK -> Phase 2")
        };
end
