package com.ftn.sbnz.rules;

import java.lang.Math;
import java.time.LocalDateTime;

import com.ftn.sbnz.model.Aggregated15minSmoke;
import com.ftn.sbnz.model.Aggregated45minSmoke;
import com.ftn.sbnz.model.Aggregated4hDryer;
import com.ftn.sbnz.model.Batch;
import com.ftn.sbnz.model.BatchStatus;
import com.ftn.sbnz.model.DryerTemperatureEvent;
import com.ftn.sbnz.model.FermentationAtRiskEvent;
import com.ftn.sbnz.model.PhMeasurementEvent;
import com.ftn.sbnz.model.ProductionPhase;
import com.ftn.sbnz.model.SlowPhTrendEvent;
import com.ftn.sbnz.model.SmokeTemperatureEvent;

declare SmokeTemperatureEvent
    @role(event)
    @timestamp(timestampMillis)
    @expires(2h)
end

declare DryerTemperatureEvent
    @role(event)
    @timestamp(timestampMillis)
    @expires(24h)
end

declare PhMeasurementEvent
    @role(event)
    @expires(7d)
end

declare SlowPhTrendEvent
    @role(event)
    @expires(7d)
end

declare FermentationAtRiskEvent
    @role(event)
    @expires(7d)
end

// ============================================================
//  CEP - chained aggregation and trend detection
// ============================================================

// C-1: Smoke temperature events are aggregated into 15-minute windows.
rule "C-1 CEP aggregate smoke temperature into 15-minute window"
    salience 120
    no-loop
    when
        $event : SmokeTemperatureEvent($batchId : batchId, $windowStart : windowStart15Min)
        not Aggregated15minSmoke(batchId == $batchId, windowStart == $windowStart)
        accumulate(
            SmokeTemperatureEvent(
                batchId == $batchId,
                windowStart15Min == $windowStart,
                $temperature : temperature
            );
            $count : count($temperature),
            $avg : average($temperature),
            $min : min($temperature),
            $max : max($temperature)
        )
    then
        insert(new Aggregated15minSmoke(
            $batchId,
            $windowStart,
            $avg,
            $min,
            $max,
            $count
        ));
        System.out.println("  >> CEP C-1 [" + $batchId + "]: Aggregated15min_Smoke "
            + $windowStart + " avg=" + String.format("%.2f", ((Number) $avg).doubleValue())
            + " min=" + String.format("%.2f", ((Number) $min).doubleValue())
            + " max=" + String.format("%.2f", ((Number) $max).doubleValue()));
end

// C-2: Three consecutive 15-minute smoke aggregates are chained into a 45-minute aggregate.
rule "C-2 CEP chain three smoke aggregates into 45-minute window"
    salience 110
    no-loop
    when
        $a1 : Aggregated15minSmoke($batchId : batchId, $start : windowStart)
        $a2 : Aggregated15minSmoke(batchId == $batchId, windowStart == $start.plusMinutes(15))
        $a3 : Aggregated15minSmoke(batchId == $batchId, windowStart == $start.plusMinutes(30))
        not Aggregated45minSmoke(batchId == $batchId, windowStart == $start)
    then
        double avg = ($a1.getAverageTemperature() + $a2.getAverageTemperature() + $a3.getAverageTemperature()) / 3.0;
        double min = Math.min($a1.getMinTemperature(), Math.min($a2.getMinTemperature(), $a3.getMinTemperature()));
        double max = Math.max($a1.getMaxTemperature(), Math.max($a2.getMaxTemperature(), $a3.getMaxTemperature()));

        insert(new Aggregated45minSmoke($batchId, $start, avg, min, max));
        System.out.println("  >> CEP C-2 [" + $batchId + "]: Aggregated45min_Smoke "
            + $start + " avg=" + String.format("%.2f", avg));
end

// C-2 escalation: 45-minute average below 60 C activates F4-4 insufficient heat treatment.
rule "C-2 CEP insufficient thermal treatment from 45-minute smoke aggregate"
    salience 100
    no-loop
    when
        $b : Batch(
            $batchId : id,
            currentPhase == ProductionPhase.SMOKING,
            status != BatchStatus.BLOCKED
        )
        $a : Aggregated45minSmoke(batchId == $batchId, averageTemperature < 60.0)
        eval(!$b.hasActiveAlert("F4-4:"))
    then
        modify($b) {
            addAlert("F4-4: InsufficientHeatTreatment - 45-minute smoke aggregate average = "
                + String.format("%.2f", $a.getAverageTemperature()) + " C (< 60 C). CRITICAL!")
        };
end

// C-3: Two consecutive daily pH readings create slow-trend events when the drop is too small.
rule "C-3 CEP detect slow pH drop between consecutive days"
    salience 120
    no-loop
    when
        $previous : PhMeasurementEvent($batchId : batchId, $fromDay : day, $previousPh : ph)
        $current : PhMeasurementEvent(batchId == $batchId, day == $fromDay + 1, $currentPh : ph)
        eval(($previousPh - $currentPh) < 0.1)
        not SlowPhTrendEvent(batchId == $batchId, fromDay == $fromDay, toDay == $fromDay + 1)
    then
        double delta = $previousPh - $currentPh;
        insert(new SlowPhTrendEvent($batchId, $fromDay, $fromDay + 1, delta));
        System.out.println("  >> CEP C-3 [" + $batchId + "]: SlowPhTrend day "
            + $fromDay + "->" + ($fromDay + 1) + " delta=" + String.format("%.2f", delta));
end

// C-4: Two consecutive slow pH trend events activate fermentation risk.
rule "C-4 CEP chain slow pH trend events into fermentation risk"
    salience 110
    no-loop
    when
        $e1 : SlowPhTrendEvent($batchId : batchId, $fromDay : fromDay, $middleDay : toDay)
        $e2 : SlowPhTrendEvent(batchId == $batchId, fromDay == $middleDay, $lastDay : toDay)
        not FermentationAtRiskEvent(batchId == $batchId, firstSlowDay == $fromDay, lastSlowDay == $lastDay)
    then
        insert(new FermentationAtRiskEvent($batchId, $fromDay, $lastDay));
        System.out.println("  >> CEP C-4 [" + $batchId + "]: FermentationAtRisk from day "
            + $fromDay + " to day " + $lastDay);
end

rule "C-4 CEP fermentation risk alert"
    salience 100
    no-loop
    when
        $b : Batch(
            $batchId : id,
            currentPhase == ProductionPhase.FERMENTATION,
            status != BatchStatus.BLOCKED
        )
        $risk : FermentationAtRiskEvent(batchId == $batchId)
        eval(!$b.hasActiveAlert("F3-6:"))
    then
        modify($b) {
            addAlert("F3-6: FermentationAtRisk - chained slow pH trend events from day "
                + $risk.getFirstSlowDay() + " to day " + $risk.getLastSlowDay())
        };
end

// C-5: Dryer temperature events are aggregated into 4-hour windows.
rule "C-5 CEP aggregate dryer temperature into 4-hour window"
    salience 120
    no-loop
    when
        $event : DryerTemperatureEvent($batchId : batchId, $windowStart : windowStart4h)
        not Aggregated4hDryer(batchId == $batchId, windowStart == $windowStart)
        accumulate(
            DryerTemperatureEvent(
                batchId == $batchId,
                windowStart4h == $windowStart,
                $temperature : temperature
            );
            $count : count($temperature),
            $avg : average($temperature),
            $min : min($temperature),
            $max : max($temperature)
        )
    then
        insert(new Aggregated4hDryer(
            $batchId,
            $windowStart,
            $avg,
            $min,
            $max,
            $count
        ));
        System.out.println("  >> CEP C-5 [" + $batchId + "]: Aggregated4h_Dryer "
            + $windowStart + " avg=" + String.format("%.2f", ((Number) $avg).doubleValue()));
end

rule "C-5 CEP persistent dryer temperature risk"
    salience 100
    no-loop
    when
        $b : Batch(
            $batchId : id,
            currentPhase == ProductionPhase.DRYING_AGING,
            status != BatchStatus.BLOCKED
        )
        $a : Aggregated4hDryer(batchId == $batchId, averageTemperature > 16.0)
        eval(!$b.hasActiveAlert("F5-5:"))
    then
        modify($b) {
            addAlert("F5-5: PersistentDryingTemperatureRisk - 4-hour dryer aggregate average = "
                + String.format("%.2f", $a.getAverageTemperature()) + " C (> 16 C)")
        };
end
